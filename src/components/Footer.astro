---
import { SITE } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="border-t border-subtle mt-20">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-sm text-ink-muted">
    <div>
      <span class="font-mono text-xs text-ink-soft">© {year}</span>
      <span class="ml-2">{SITE.name}.</span>
    </div>
    <div class="flex items-center gap-4">
      <a href={SITE.social.github} class="hover:text-accent transition-colors" rel="me">GitHub</a>
      <a href={SITE.social.linkedin} class="hover:text-accent transition-colors" rel="me">LinkedIn</a>
      <a href={`${base}/rss.xml`} class="hover:text-accent transition-colors">RSS</a>
    </div>
  </div>
</footer>
