---
import { SITE, NAV } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';
---

<header class="border-b border-subtle">
  <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href={`${base}/`} class="group">
      <div class="font-display text-xl font-semibold tracking-tight leading-none">
        {SITE.name}
      </div>
      <div class="text-xs text-ink-soft mt-0.5 font-mono uppercase tracking-wider">
        Solution Architect · Notes
      </div>
    </a>

    <nav class="flex items-center gap-1">
      {
        NAV.map(({ label, href }) => {
          const isActive = currentPath.startsWith(href) && href !== '/';
          return (
            <a
              href={`${base}${href}`}
              class:list={[
                'px-3 py-2 text-sm rounded hover:bg-paper-soft transition-colors',
                isActive ? 'text-accent font-medium' : 'text-ink-muted',
              ]}
            >
              {label}
            </a>
          );
        })
      }
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>
