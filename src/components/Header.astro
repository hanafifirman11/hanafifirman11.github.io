---
import { SITE, NAV } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import { getLocalizedPath } from '../i18n/utils';

interface Props {
  lang?: 'id' | 'en';
}

const { lang = 'en' } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';

// Build the equivalent path in the other language
const targetLang = lang === 'en' ? 'id' : 'en';
const switchPath = getLocalizedPath(currentPath, targetLang);
const switchHref = `${base}${switchPath}`;
const switchLabel = lang === 'en' ? 'ID' : 'EN';

// For nav active detection — strip /id prefix for Indonesian pages
const normalizedPath = currentPath.startsWith('/id/')
  ? currentPath.slice(3)
  : currentPath === '/id'
  ? '/'
  : currentPath;
---

<header class="border-b border-subtle">
  <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href={lang === 'id' ? `${base}/id` : `${base}/`} class="group">
      <div class="font-display text-xl font-semibold tracking-tight leading-none">
        {SITE.name}
      </div>
      <div class="text-xs text-ink-soft mt-0.5 font-mono uppercase tracking-wider">
        Solution Architect · Notes
      </div>
    </a>

    <nav class="flex items-center gap-1">
      {
        NAV.map(({ label, href }) => {
          const isActive = normalizedPath.startsWith(href) && href !== '/';
          const localizedHref = lang === 'id' ? `/id${href}` : href;
          return (
            <a
              href={`${base}${localizedHref}`}
              class:list={[
                'px-3 py-2 text-sm rounded hover:bg-paper-soft transition-colors',
                isActive ? 'text-accent font-medium' : 'text-ink-muted',
              ]}
            >
              {label}
            </a>
          );
        })
      }

      <!-- Language switcher -->
      <a
        href={switchHref}
        class="ml-1 px-2 py-1 text-xs font-mono rounded border border-subtle hover:bg-paper-soft hover:text-accent transition-colors text-ink-soft"
        title={lang === 'en' ? 'Beralih ke Bahasa Indonesia' : 'Switch to English'}
      >
        {switchLabel}
      </a>

      <div class="ml-2">
        <ThemeToggle />
      </div>
    </nav>
  </div>
</header>
