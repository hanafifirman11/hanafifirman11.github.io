---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const lang = 'id';
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ id, data }) =>
  id.endsWith('/id.md') && !data.draft
);

const posts = allPosts.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// Group by year
const postsByYear = posts.reduce((acc, post) => {
  const year = post.data.publishedAt.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof posts>);

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={t('blog.h1')}
  description={t('blog.description')}
  lang={lang}
>
  <section class="max-w-3xl mx-auto px-6 py-12 md:py-16 animate-rise">
    <header class="mb-12 pb-8 border-b border-subtle">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-ink-soft mb-4">
        {t('blog.eyebrow')}
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-4">
        {t('blog.h1')}
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed">
        {t('blog.description')}
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-ink-muted italic py-12 text-center">{t('blog.empty')}</p>
      ) : (
        years.map((year) => (
          <section class="mb-12">
            <h2 class="font-mono text-sm text-ink-soft mb-4 pb-2 border-b border-subtle">
              {year}
            </h2>
            {postsByYear[year].map((post) => (
              <PostCard
                href={`${base}/id/blog/${post.slug.replace(/\/id$/, '')}`}
                title={post.data.title}
                description={post.data.description}
                publishedAt={post.data.publishedAt}
                category={post.data.category}
                tags={post.data.tags}
              />
            ))}
          </section>
        ))
      )
    }
  </section>
</BaseLayout>
