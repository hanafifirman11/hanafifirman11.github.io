              </div>
            </div>
            <div class="casestudy-tech">
              <span class="skill-tag">Spring Boot WebFlux</span>
              <span class="skill-tag">Spring MVC</span>
              <span class="skill-tag">Reactive</span>
            </div>
          </div>

          <!-- QRIS Merchant Onboarding -->
          <div class="casestudy-card">
            <div class="casestudy-header">
              <span class="icon">📱</span>
              <span class="title">QRIS Merchant Onboarding</span>
            </div>
            <div class="casestudy-flow">
              <div class="casestudy-step">
                <span class="step-label problem">Problem</span>
