          <!-- n8n Self-Hosted on K8s -->
          <div class="casestudy-card">
            <div class="casestudy-header">
              <span class="icon">🔧</span>
              <span class="title">n8n Self-Hosted on Kubernetes</span>
            </div>
            <div class="casestudy-flow">
              <div class="casestudy-step">
                <span class="step-label problem">Problem</span>
                <span class="step-text">Need a scalable, reliable workflow automation platform for internal engineering use</span>
              </div>
              <div class="casestudy-step">
