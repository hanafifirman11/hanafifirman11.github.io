---
import BaseLayout from '../layouts/BaseLayout.astro';

// Edit daftar project kamu di sini — struktur ini sengaja simple biar gampang maintain
const projects = [
  {
    title: 'Solution Design for [Product Name]',
    role: 'Solution Architect',
    period: '2024 — present',
    summary:
      'Designed end-to-end architecture for [brief description]. Led design decisions on data flow, integration pattern, and deployment strategy.',
    stack: ['Architecture', 'Microservices', 'Event-Driven'],
    link: null,
  },
  {
    title: 'AI Coding Assistant Evaluation',
    role: 'POC Lead',
    period: '2024',
    summary:
      'Benchmark study on Claude, Copilot, and Cursor for our engineering workflow. Measured impact on PR velocity, review quality, and developer experience.',
    stack: ['AI', 'Developer Tooling', 'Research'],
    link: null,
  },
  {
    title: 'Personal portfolio & blog',
    role: 'Self-directed',
    period: '2026',
    summary:
      'This site. Built with Astro, deployed on GitHub Pages. Writing notes as I go.',
    stack: ['Astro', 'Tailwind', 'MDX'],
    link: 'https://github.com/hanafifirman11',
  },
];

const skills = {
  'Architecture & Design': [
    'Solution design',
    'System architecture',
    'API design',
    'Event-driven patterns',
    'Microservices',
    'Integration patterns',
  ],
  'AI & Engineering': [
    'LLM integration',
    'AI coding tools evaluation',
    'Prompt engineering for engineering workflows',
    'POC development',
  ],
  'Craft': [
    'Technical writing',
    'Engineer mentoring',
    'Stakeholder communication',
    'Trade-off analysis',
  ],
};
---

<BaseLayout
  title="Portfolio"
  description="Selected work as a solution architect — system designs, POCs, and technical leadership projects."
>
  <section class="max-w-3xl mx-auto px-6 py-12 md:py-16 animate-rise">
    <header class="mb-12 pb-8 border-b border-subtle">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-ink-soft mb-4">
        Portfolio
      </p>
      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-4">
        Selected work
      </h1>
      <p class="text-lg text-ink-muted leading-relaxed">
        I work as a solution architect, mostly designing systems for product and
        technology needs and running POCs on AI for software engineering. Below
        are a few things I've worked on.
      </p>
    </header>

    <!-- Projects -->
    <section class="mb-16">
      <h2 class="font-mono text-sm text-ink-soft mb-6 pb-2 border-b border-subtle">
        Projects
      </h2>
      <div class="space-y-10">
        {
          projects.map((project) => (
            <article>
              <div class="flex items-baseline justify-between gap-4 mb-2 flex-wrap">
                <h3 class="font-display text-xl font-semibold leading-tight">
                  {project.link ? (
                    <a href={project.link} class="hover:text-accent transition-colors">
                      {project.title}
                    </a>
                  ) : (
                    project.title
                  )}
                </h3>
                <span class="font-mono text-xs text-ink-soft whitespace-nowrap">
                  {project.period}
                </span>
              </div>
              <p class="text-sm text-accent font-medium mb-3">{project.role}</p>
              <p class="text-ink-muted leading-relaxed mb-3">{project.summary}</p>
              <div class="flex flex-wrap gap-2">
                {project.stack.map((tag) => (
                  <span class="text-xs font-mono px-2 py-1 rounded bg-paper-soft text-ink-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Skills -->
    <section>
      <h2 class="font-mono text-sm text-ink-soft mb-6 pb-2 border-b border-subtle">
        What I work with
      </h2>
      <div class="space-y-6">
        {
          Object.entries(skills).map(([category, items]) => (
            <div>
              <h3 class="font-display text-lg font-semibold mb-3">{category}</h3>
              <div class="flex flex-wrap gap-2">
                {items.map((item) => (
                  <span class="text-sm px-3 py-1 rounded-full border border-subtle text-ink-muted">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>
