---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id, data }) => id.endsWith('/en.md') && !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang={lang}>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-12 md:pt-24 md:pb-16 animate-rise">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-ink-soft mb-6">
        {t('hero.eyebrow')}
      </p>
      <h1 class="font-display text-4xl md:text-6xl font-semibold leading-[1.05] tracking-tight mb-6">
        {t('hero.h1.line1')}<br />
        <span class="text-accent italic">{t('hero.h1.line2')}</span><br />
        {t('hero.h1.line3')}
      </h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-2xl">
        {t('hero.description')}
      </p>
      <div class="flex gap-4 mt-8">
        <a
          href={`${base}/blog`}
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-ink text-paper rounded-full text-sm font-medium hover:bg-accent transition-colors"
          style="background: var(--color-ink); color: var(--color-bg);"
        >
          {t('hero.cta.blog')}
        </a>
        <a
          href={`${base}/portfolio`}
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-subtle rounded-full text-sm font-medium hover:bg-paper-soft transition-colors"
        >
          {t('hero.cta.portfolio')}
        </a>
      </div>

      <!-- Hero Stats -->
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="number">11+</div>
          <div class="label">{t('hero.stats.years')}</div>
        </div>
        <div class="hero-stat">
          <div class="number">9+</div>
          <div class="label">{t('hero.stats.payment')}</div>
        </div>
        <div class="hero-stat">
          <div class="number">2</div>
          <div class="label">{t('hero.stats.oss')}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent writing -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex items-baseline justify-between mb-8 pb-4 border-b border-subtle">
      <h2 class="font-display text-2xl font-semibold">{t('blog.recentWriting')}</h2>
      <a href={`${base}/blog`} class="text-sm text-accent hover:underline">{t('blog.allPosts')}</a>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-ink-muted italic py-8">{t('blog.empty')}</p>
      ) : (
        <div>
          {posts.map((post) => (
            <PostCard
              href={`${base}/blog/${post.slug.replace(/\/en$/, '')}`}
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              category={post.data.category}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
