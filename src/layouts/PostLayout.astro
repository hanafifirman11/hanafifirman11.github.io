---
import BaseLayout from './BaseLayout.astro';
import { CATEGORIES } from '../consts';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  category: string;
  tags: string[];
  lang?: 'id' | 'en';
}

const { title, description, publishedAt, updatedAt, category, tags, lang = 'id' } = Astro.props;

const locale = lang === 'en' ? 'en-US' : 'id-ID';
const formatter = new Intl.DateTimeFormat(locale, {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const categoryLabel = CATEGORIES[category]?.label ?? category;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const blogBase = lang === 'en' ? `${base}/en/blog` : `${base}/blog`;
const backLabel = '← Blog';
const backAllLabel = lang === 'en' ? '← Back to all writing' : '← Back to all writing';
const discussionLabel = lang === 'en' ? 'Discussion' : 'Diskusi';
const updatedLabel = lang === 'en' ? 'Updated' : 'Updated';
---

<BaseLayout
  title={title}
  description={description}
  article={true}
  publishedTime={publishedAt.toISOString()}
  lang={lang}
>
  <article class="max-w-3xl mx-auto px-6 py-12 animate-rise">
    <!-- Article header -->
    <header class="mb-12 pb-8 border-b border-subtle">
      <div class="flex items-baseline gap-3 mb-4 text-xs font-mono uppercase tracking-wider text-ink-soft">
        <a href={blogBase} class="hover:text-accent transition-colors">{backLabel}</a>
        <span>·</span>
        <span class="text-accent">{categoryLabel}</span>
      </div>

      <h1 class="font-display text-4xl md:text-5xl font-semibold leading-[1.1] tracking-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-ink-muted leading-relaxed mb-6">
        {description}
      </p>

      <div class="flex items-center gap-3 text-sm text-ink-soft font-mono">
        <time datetime={publishedAt.toISOString()}>
          {formatter.format(publishedAt)}
        </time>
        {
          updatedAt && (
            <>
              <span>·</span>
              <span>{updatedLabel} {formatter.format(updatedAt)}</span>
            </>
          )
        }
      </div>
    </header>

    <!-- Article body -->
    <div class="prose-editorial">
      <slot />
    </div>

    <!-- Article footer -->
    <footer class="mt-16 pt-8 border-t border-subtle">
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {tags.map((tag) => (
              <span class="text-xs font-mono px-2 py-1 rounded bg-paper-soft text-ink-muted">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
      <a href={blogBase} class="text-sm text-accent hover:underline">
        {backAllLabel}
      </a>
    </footer>

    <!-- Giscus: Comments & Reactions -->
    <section class="max-w-3xl mx-auto px-6 pb-16 mt-4">
      <div class="border-t border-subtle pt-10">
        <h2 class="font-display text-xl font-semibold mb-6 text-ink">{discussionLabel}</h2>
        <div id="giscus-container"></div>
      </div>
    </section>
  </article>

  <script type="module" is:inline>
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    import elkLayouts from 'https://cdn.jsdelivr.net/npm/@mermaid-js/layout-elk@0.2.1/dist/mermaid-layout-elk.esm.min.mjs';

    mermaid.registerLayoutLoaders(elkLayouts);

    const theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default';
    mermaid.initialize({
      startOnLoad: false,
      theme: theme,
      fontFamily: "'Inter Tight', system-ui, sans-serif",
    });

    await mermaid.run({ querySelector: '.mermaid' });
  </script>

  <style>
    .mermaid {
      display: flex;
      justify-content: center;
      margin: 2em 0;
      overflow-x: auto;
      background: transparent !important;
    }

    .mermaid svg {
      max-width: 100%;
      height: auto;
    }
  </style>
  <script is:inline>
    // Giscus initialization — respects current theme
    function loadGiscus() {
      const container = document.getElementById('giscus-container');
      if (!container) return;

      const theme = document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark_dimmed'
        : 'light';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'hanafifirman11/hanafifirman11.github.io');
      script.setAttribute('data-repo-id', 'R_kgDOSJInEw');
      script.setAttribute('data-category', 'General');
      script.setAttribute('data-category-id', 'DIC_kwDOSJInE84C7eDr');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'top');
      script.setAttribute('data-theme', theme);
      script.setAttribute('data-lang', 'id');
      script.setAttribute('data-loading', 'lazy');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;
      container.appendChild(script);
    }

    // Also update Giscus theme when user toggles dark/light
    function updateGiscusTheme() {
      const theme = document.documentElement.getAttribute('data-theme') === 'dark'
        ? 'dark_dimmed'
        : 'light';
      const iframe = document.querySelector('.giscus-frame');
      if (iframe) {
        iframe.contentWindow.postMessage(
          { giscus: { setConfig: { theme } } },
          'https://giscus.app'
        );
      }
    }

    loadGiscus();

    // Watch for theme changes
    const observer = new MutationObserver(() => updateGiscusTheme());
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  </script>
</BaseLayout>
